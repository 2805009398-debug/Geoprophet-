# 依赖目录
node_modules

# 本地工具和构建产物
.tools
dist
frontend/dist

# 系统和运行时缓存
.DS_Store
__pycache__/
.pytest_cache/
.venv/

# 后端本地数据库文件
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# 用户上传文件，仅保留目录占位文件
backend/uploads/*
!backend/uploads/.gitkeep

# 模型文件体积较大，仅保留目录占位文件
model-service/models/*
!model-service/models/.gitkeep

# 日志文件
npm-debug.log*

# 生产环境变量文件，避免提交敏感配置
.env.production
